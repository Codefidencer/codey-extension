<UserControl x:Class="Codey.Extension.ToolWindows.CodeyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="380"
             Background="#0D0D0D">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>    <!-- Header -->
            <RowDefinition Height="42"/>    <!-- Progress + XP -->
            <RowDefinition Height="38"/>    <!-- Filters -->
            <RowDefinition Height="175"/>   <!-- Exercise list -->
            <RowDefinition Height="Auto"/>  <!-- Task expander -->
            <RowDefinition Height="48"/>    <!-- Action buttons -->
            <RowDefinition Height="90"/>    <!-- Output -->
            <RowDefinition Height="2*"/>    <!-- Tutor panel -->
        </Grid.RowDefinitions>

        <!-- ── ROW 0: HEADER ───────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#111827">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Image Source="pack://application:,,,/Codey.Extension;component/codey_icon_small.png"
                       Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,7,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="CODEY C# TUTOR"
                           Foreground="#00E5FF" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1"
                    x:Name="BtnSettings" Content="&#x2699;" Click="BtnSettings_Click"
                    Background="Transparent" Foreground="#556677" BorderThickness="0"
                    FontSize="17" Cursor="Hand" Width="36"
                    ToolTip="Settings — configure Ollama model and endpoint"/>
        </Grid>

        <!-- ── ROW 1: PROGRESS + XP ───────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Background="#0D0D0D" Margin="10,3,10,2"
                    VerticalAlignment="Center">
            <!-- Progress bar + count -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0"
                             x:Name="ProgressBar"
                             Background="#1A2030" Foreground="#00E5FF"
                             BorderThickness="0" Height="5"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="ProgressText"
                           Foreground="#445566" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
            <!-- XP row -->
            <TextBlock x:Name="XpText"
                       Foreground="#FFD700" FontSize="12" FontWeight="SemiBold"
                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ── ROW 2: FILTER BUTTONS ───────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    Background="#0D0D0D" VerticalAlignment="Center" Margin="8,0">
            <Button x:Name="BtnAll"          Content="All"          Tag="All"
                    Click="FilterBtn_Click"
                    Background="#00E5FF" Foreground="#000000"
                    BorderThickness="0" Padding="10,4" Margin="0,0,4,0"
                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"/>
            <Button x:Name="BtnBeginner"     Content="Beginner"     Tag="Beginner"
                    Click="FilterBtn_Click"
                    Background="#1A2030" Foreground="#556677"
                    BorderThickness="0" Padding="10,4" Margin="0,0,4,0"
                    FontSize="12" Cursor="Hand"/>
            <Button x:Name="BtnIntermediate" Content="Intermediate" Tag="Intermediate"
                    Click="FilterBtn_Click"
                    Background="#1A2030" Foreground="#556677"
                    BorderThickness="0" Padding="10,4" Margin="0,0,4,0"
                    FontSize="12" Cursor="Hand"/>
            <Button x:Name="BtnAdvanced"     Content="Advanced"     Tag="Advanced"
                    Click="FilterBtn_Click"
                    Background="#1A2030" Foreground="#556677"
                    BorderThickness="0" Padding="10,4"
                    FontSize="12" Cursor="Hand"/>
        </StackPanel>

        <!-- ── ROW 3: EXERCISE LIST ────────────────────────────────────────── -->
        <ListBox Grid.Row="3"
                 x:Name="ExerciseList"
                 Background="#0A0F1A" BorderThickness="0"
                 Margin="8,2,8,2"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="ExerciseList_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"    Value="8,6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#001A2B"/>
                            <Setter Property="BorderBrush" Value="#00E5FF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0D1F30"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- ── ROW 4: TASK EXPANDER ────────────────────────────────────────── -->
        <Expander Grid.Row="4"
                  x:Name="TaskExpander"
                  Background="#080D14" IsExpanded="True"
                  Margin="8,2,8,2">
            <Expander.Header>
                <TextBlock Foreground="#00E5FF" FontSize="12" FontWeight="SemiBold"
                           Text="&#x1F4CB; Task"/>
            </Expander.Header>
            <ScrollViewer MaxHeight="95" VerticalScrollBarVisibility="Auto"
                          Background="#080D14">
                <TextBlock x:Name="TaskText"
                           Foreground="#8899BB" FontSize="12"
                           TextWrapping="Wrap" Margin="8,4,8,6"/>
            </ScrollViewer>
        </Expander>

        <!-- ── ROW 5: ACTION BUTTONS ───────────────────────────────────────── -->
        <Grid Grid.Row="5" Background="#0D0D0D">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,4">
                <Button x:Name="BtnOpenInEditor" Content="&#x1F4C2; Open in VS"
                        Click="OpenInEditorBtn_Click"
                        Background="#003355" Foreground="#00E5FF" BorderThickness="0"
                        Padding="12,6" Margin="0,0,5,0"
                        FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                        ToolTip="Open exercise code in VS editor with live AI review"/>
                <Button x:Name="BtnRun"
                        Click="RunBtn_Click"
                        Background="#00AA44" Foreground="White" BorderThickness="0"
                        Padding="10,5" Margin="0,0,5,0"
                        Cursor="Hand" ToolTip="Compile and run your code">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#00CC55"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#008833"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A3A1A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x25B6;" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Run" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnHint"     Content="&#x1F4A1; Hint"
                        Click="HintBtn_Click"
                        Background="#1A3A5C" Foreground="#7EC8FF" BorderThickness="0"
                        Padding="12,6" Margin="0,0,5,0"
                        FontSize="12" Cursor="Hand"/>
                <Button x:Name="BtnSolution" Content="&#x1F441; Solution"
                        Click="SolutionBtn_Click"
                        Background="#2A1A3A" Foreground="#BB88FF" BorderThickness="0"
                        Padding="12,6" Margin="0,0,5,0"
                        FontSize="12" Cursor="Hand"/>
                <Button x:Name="BtnDone"     Content="&#x2713; Done"
                        Click="DoneBtn_Click"
                        Background="#1A2A1A" Foreground="#88BB88" BorderThickness="0"
                        Padding="12,6"
                        FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- ── ROW 6: OUTPUT ───────────────────────────────────────────────── -->
        <Grid Grid.Row="6" Margin="8,0,8,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="Output" Foreground="#334455" FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="1"
                     x:Name="OutputBox"
                     Background="#06090F" Foreground="#FFD700"
                     FontFamily="Consolas" FontSize="12"
                     BorderBrush="#1A2030" BorderThickness="1"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- ── ROW 7: TUTOR PANEL ──────────────────────────────────────────── -->
        <Grid Grid.Row="7" Background="#060D12">
            <Grid.RowDefinitions>
                <RowDefinition Height="22"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="Tutor" Foreground="#334455" FontSize="12"
                       VerticalAlignment="Center" Margin="10,0"/>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="8,0,8,6">
                <TextBlock x:Name="TutorText"
                           Foreground="#CCD6F6" FontSize="13"
                           TextWrapping="Wrap" LineHeight="20"/>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
